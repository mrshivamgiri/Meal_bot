# Ordered model fallback chain: "provider/model,provider/model,..."
# First model is primary; subsequent models are tried on quota errors (429).
LLM_MODELS=deepseek/deepseek-chat,gemini/gemini-2.5-flash,gemini/gemini-2.5-flash-lite

# Get your keys at https://aistudio.google.com/ and https://platform.openai.com/

# Gemini API (free tier from Google AI Studio)
GEMINI_API_KEY=your_key_here

# OpenAI (optional)
OPENAI_API_KEY=your_key_here

DEEPSEEK_API_KEY=your_key_here

# Postgres credentials (used by docker-compose.yml)
# PRODUCTION: use strong values — e.g. `openssl rand -base64 32` for password
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mealbot

DATABASE_URL=postgresql+psycopg://user:password@db:5432/mealbot
DB_ECHO=False

# Optional local mock mode (set to "true" to bypass real API)
LLM_MOCK=false

# Optional RAG usage — retrieves highly-rated past meals as prompt context.
# Retrieval is hybrid: RAG_OWN_USER_FETCH closest own-user meals PLUS
# RAG_GLOBAL_FETCH closest meals across all users, merged and deduped. This
# guarantees own-user history is represented regardless of corpus size — a
# single global top-K wouldn't, once other users' data dominates.
# RAG_USER_BOOST multiplies own-user distances (< 1.0 = boost) during the
# final re-rank. 0.7 means own meals at distance 0.5 rank as distance 0.35.
# Hits with adjusted_distance >= RAG_MAX_DISTANCE are dropped; if fewer than
# RAG_MIN_RESULTS survive, we fall back to the standard pipeline.
# Surviving hits are truncated to RAG_MAX_CONTEXT_MEALS before reaching the
# LLM — token cost is linear in example count, quality gains plateau past ~8.
USE_RAG=false
RAG_OWN_USER_FETCH=5
RAG_GLOBAL_FETCH=15
RAG_MIN_RESULTS=3
RAG_MAX_DISTANCE=0.4
RAG_USER_BOOST=0.7
RAG_MAX_CONTEXT_MEALS=8

# LLM consistency testing
RUN_LLM_TESTS=false

# REQUIRED: Generate a strong random key (e.g. `openssl rand -hex 32`)
SECRET_KEY=CHANGE_ME

# Comma-separated list of allowed frontend origins
# PRODUCTION: set to your domain, e.g. https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# PRODUCTION: set to your domain for Caddy SSL
# DOMAIN=yourdomain.com

# Set to true to allow public registration (false = closed alpha)
REGISTRATION_ENABLED=true

# Set to true to enable the /api/demo/session endpoint and show the
# "Try Demo" button. Demo users get mocked LLM responses automatically
# (per-user, so alpha accounts still hit the real LLM on the same server).
DEMO_MODE=false

# Access token (HttpOnly cookie) lifetime in minutes. 15 is the recommended
# default; refresh tokens keep active sessions alive without re-prompting.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token (HttpOnly cookie) lifetime in days. Sliding — every refresh
# resets the window. Idle past this and the user re-logs in.
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie attributes.
#   PRODUCTION: leave COOKIE_SECURE=true so cookies require TLS.
#   DEV (`docker compose up`, no Caddy): the Vite dev server runs on plain
#     http://localhost:5174 — set COOKIE_SECURE=false in your local .env
#     or the browser will silently drop the Set-Cookie response and you'll
#     see no auth cookies in DevTools. SameSite stays Lax in both modes.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Double-submit-cookie CSRF middleware. Leave on; off is for emergencies.
CSRF_ENABLED=true

# Optional Hugging Face read token. Used only during `docker build` to
# authenticate the one-time embedding-model download. Unset = anonymous
# (still works, just louder warnings and lower rate limits). Create one
# at https://huggingface.co/settings/tokens (type: Read).
HF_TOKEN=