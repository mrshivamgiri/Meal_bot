# Ordered model fallback chain: "provider/model,provider/model,..."
# First model is primary; subsequent models are tried on quota errors (429).
LLM_MODELS=deepseek/deepseek-chat,gemini/gemini-2.5-flash,gemini/gemini-2.5-flash-lite

# Get your keys at https://aistudio.google.com/ and https://platform.openai.com/

# Gemini API (free tier from Google AI Studio)
GEMINI_API_KEY=your_key_here

# OpenAI (optional)
OPENAI_API_KEY=your_key_here

DEEPSEEK_API_KEY=your_key_here

# Postgres credentials (used by docker-compose.yml)
# PRODUCTION: use strong values — e.g. `openssl rand -base64 32` for password
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mealbot

DATABASE_URL=postgresql+psycopg://user:password@db:5432/mealbot
DB_ECHO=False

# Optional local mock mode (set to "true" to bypass real API)
LLM_MOCK=false

# Optional RAG usage
USE_RAG=false

# LLM consistency testing
RUN_LLM_TESTS=false

# REQUIRED: Generate a strong random key (e.g. `openssl rand -hex 32`)
SECRET_KEY=CHANGE_ME

# Comma-separated list of allowed frontend origins
# PRODUCTION: set to your domain, e.g. https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# PRODUCTION: set to your domain for Caddy SSL
# DOMAIN=yourdomain.com

# Set to true to allow public registration (false = closed alpha)
REGISTRATION_ENABLED=true

# Token expiry in minutes (default 1440 = 24h, dev override 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080